# ============================================
# CONFIGURACIÓN DEL SERVIDOR — CABA ONLINE
# Copiar este archivo como .env y completar
# NUNCA subir .env a git
# ============================================

# Servidor
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Supabase (obtener en supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=cambiar_por_secreto_muy_largo_y_seguro_minimo_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Noticias (opcional - RSS no necesita key)
NEWS_REFRESH_INTERVAL_MINUTES=30

# Admin
ADMIN_SECRET=cambiar_por_secreto_admin
